# agente-tjms — configuração de alertas via Telegram
# Copie pra ~/.config/agente-tjms/agente-tjms.env e preencha os 3 campos.
# Esse arquivo NÃO deve ser versionado (token sensível).

# Path absoluto do repo (sem trailing slash)
AGENTE_TJMS_HOME=/home/SEU_USUARIO/projetos/agente-tjms

# Bot Telegram — obtenha via @BotFather (/newbot)
AGENTE_TJMS_TG_TOKEN=000000000:AAAA-XXXX_TROQUE_ESSE_VALOR

# Chat ID destino — após enviar /start pro bot, rode:
#   curl "https://api.telegram.org/bot${AGENTE_TJMS_TG_TOKEN}/getUpdates"
# e copie o campo result[0].message.chat.id da resposta JSON
AGENTE_TJMS_TG_CHAT_ID=000000000
